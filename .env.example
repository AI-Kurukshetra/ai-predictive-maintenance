# Supabase
# Required for live auth, protected routes, and database-backed persistence.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Integrations demo mode
# Keep this true if you want seeded ERP/CMMS connector responses without real vendor credentials.
INTEGRATIONS_DEMO_MODE=true

# Odoo ERP / Maintenance
# Fill these only when enabling live Odoo sync.
ODOO_BASE_URL=
ODOO_DATABASE=
ODOO_API_KEY=
ODOO_MAINTENANCE_MODEL=maintenance.request
ODOO_INVENTORY_MODEL=stock.quant
ODOO_EQUIPMENT_ID_MAP_JSON={}
ODOO_PRODUCT_ID_MAP_JSON={}

# Fracttal CMMS
# Default auth mode is hawk. Switch to bearer only if your tenant uses bearer tokens.
FRACTTAL_BASE_URL=https://api.fracttal.com
FRACTTAL_AUTH_MODE=hawk
FRACTTAL_API_KEY=
FRACTTAL_API_SECRET=
FRACTTAL_WORK_ORDER_ENDPOINT=/api/v2/work-orders/
FRACTTAL_TEST_ENDPOINT=/api/v2/work-orders/?limit=1
FRACTTAL_ASSET_ID_MAP_JSON={}
